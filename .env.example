# Copy to .env and adjust locally. Docker Compose reads these variables.

DATABASE_URL=file:./data/dev.sqlite
NUXT_DATABASE_URL=file:./data/dev.sqlite

# Public origin (must match browser URL; include https in production).
# Use the same host as in the address bar: localhost and 127.0.0.1 are different origins for cookies.
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Used by Better Auth for URLs and cookies (usually same as site URL as above).
BETTER_AUTH_URL=http://localhost:3000

# Min. 32 random bytes in production
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-in-prod

# Production (docker-compose.prod.yml + Caddy TLS)
DOMAIN=notes.example.com

# Contact email for Let's Encrypt (ACME account); required by Caddy global block
CADDY_EMAIL=you@example.com
